{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext", // Replaces "node" to fix the deprecation error
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "types": ["node", "@playwright/test"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "5.0" 
  },
  "include": ["**/*.ts"]
}